# Database（必填）
DATABASE_URL="postgresql://user:password@localhost:5432/novelscope?schema=public"

# LLM 提供商选择: deepseek（默认）| doubao
# LLM_PROVIDER="deepseek"

# DeepSeek API Key（LLM_PROVIDER=deepseek 时必填）
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"

# 豆包 API Key（LLM_PROVIDER=doubao 时必填）
# DOUBAO_API_KEY="your-doubao-api-key"

# Redis（可选，P2 缓存用）
# REDIS_URL="redis://localhost:6379"

# pgvector（可选，P1.4 向量记忆用，默认使用 DATABASE_URL 同一数据库）
# DATABASE_URL_VECTOR="postgresql://user:password@localhost:5432/novelscope"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
