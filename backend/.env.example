# Database（必填）
DATABASE_URL="postgresql://user:password@localhost:5432/novelscope?schema=public"

# DeepSeek API Key（必填，从 platform.deepseek.com/api_keys 获取）
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"

# Claude API Key（可选，P1.3 双模型对比用，未配置时仅用 DeepSeek）
# ANTHROPIC_API_KEY="sk-ant-your-claude-api-key"

# Redis（可选，P2 缓存用）
# REDIS_URL="redis://localhost:6379"

# pgvector（可选，P1.4 向量记忆用，默认使用 DATABASE_URL 同一数据库）
# DATABASE_URL_VECTOR="postgresql://user:password@localhost:5432/novelscope"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
